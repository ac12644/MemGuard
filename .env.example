# MemGuard environment template
# Copy to .env and adjust:  cp .env.example .env
#
# Defaults below are for LOCAL DEVELOPMENT (docker-compose postgres/redis,
# API via uvicorn on :8001). Production overrides are noted inline.

# ── Core ────────────────────────────────────────────────────────────
MEMGUARD_ENV=development                  # production: set to "production"
MEMGUARD_SECRET_KEY=change-me-in-production
# production: generate with  openssl rand -hex 32  — the app refuses to
# start in production with the default key.
MEMGUARD_API_PORT=8000

# ── Database ────────────────────────────────────────────────────────
# Local dev: docker-compose maps Postgres to host port 5433
DATABASE_URL=postgresql+asyncpg://memguard:memguard@localhost:5433/memguard
# production (inside docker-compose): postgresql+asyncpg://memguard:<password>@postgres:5432/memguard

# ── Redis ───────────────────────────────────────────────────────────
# Local dev: docker-compose maps Redis to host port 6380
REDIS_URL=redis://localhost:6380/0
# production (inside docker-compose): redis://redis:6379/0

# ── CORS ────────────────────────────────────────────────────────────
MEMGUARD_CORS_ORIGINS=*
# production: comma-separated origins, e.g. https://yourdomain.com,https://app.yourdomain.com

# ── LLM (optional — enables Semantic Drift / Causal Chain strategies) ─
ANTHROPIC_API_KEY=
MEMGUARD_LLM_MODEL=claude-sonnet-4-20250514
MEMGUARD_LLM_MAX_TOKENS=1024
MEMGUARD_LLM_RATE_LIMIT_RPM=60

# ── Validation defaults ─────────────────────────────────────────────
MEMGUARD_DEFAULT_TRUST_THRESHOLD=0.5      # below this = auto-flag
MEMGUARD_QUARANTINE_THRESHOLD=0.3         # below this = auto-quarantine
MEMGUARD_MAX_VALIDATION_BATCH=100
MEMGUARD_SOURCE_FETCH_TIMEOUT=10          # seconds
MEMGUARD_SOURCE_RATE_LIMIT_PER_DOMAIN=10  # requests/sec per source domain

# ── Dashboard ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8001
# production: https://api.yourdomain.com
