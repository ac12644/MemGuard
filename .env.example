# Core
MEMGUARD_ENV=development
MEMGUARD_SECRET_KEY=change-me-in-production
MEMGUARD_API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://memguard:memguard@localhost:5432/memguard

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM (for semantic validation)
ANTHROPIC_API_KEY=sk-ant-...
MEMGUARD_LLM_MODEL=claude-sonnet-4-20250514
MEMGUARD_LLM_MAX_TOKENS=1024
MEMGUARD_LLM_RATE_LIMIT_RPM=60

# Validation defaults
MEMGUARD_DEFAULT_TRUST_THRESHOLD=0.5
MEMGUARD_QUARANTINE_THRESHOLD=0.3
MEMGUARD_MAX_VALIDATION_BATCH=100
MEMGUARD_SOURCE_FETCH_TIMEOUT=10
MEMGUARD_SOURCE_RATE_LIMIT_PER_DOMAIN=10

# Dashboard
VITE_API_URL=http://localhost:8000
