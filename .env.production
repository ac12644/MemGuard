# MemGuard Production Environment
# Copy to .env and fill in real values

MEMGUARD_ENV=production
MEMGUARD_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
MEMGUARD_API_PORT=8000

# Database (use docker service name as host)
DATABASE_URL=postgresql+asyncpg://memguard:CHANGE_THIS_PASSWORD@postgres:5432/memguard

# Redis
REDIS_URL=redis://redis:6379/0

# CORS — comma-separated origins for production
MEMGUARD_CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# LLM (for semantic validation strategies)
ANTHROPIC_API_KEY=sk-ant-CHANGE_THIS
MEMGUARD_LLM_MODEL=claude-sonnet-4-20250514
MEMGUARD_LLM_MAX_TOKENS=1024
MEMGUARD_LLM_RATE_LIMIT_RPM=60

# Validation defaults
MEMGUARD_DEFAULT_TRUST_THRESHOLD=0.5
MEMGUARD_QUARANTINE_THRESHOLD=0.3
MEMGUARD_MAX_VALIDATION_BATCH=100
MEMGUARD_SOURCE_FETCH_TIMEOUT=10
MEMGUARD_SOURCE_RATE_LIMIT_PER_DOMAIN=10

# Dashboard
VITE_API_URL=https://api.yourdomain.com
